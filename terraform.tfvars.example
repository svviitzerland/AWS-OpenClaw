# AWS Configuration
aws_region   = "ap-southeast-1"
project_name = "openclaw"

# EC2 Configuration
instance_type = "t4g.medium"
key_name      = "your-key-name"

# Security - Replace with your IP for better security
allowed_ssh_cidr = ["0.0.0.0/0"]
allowed_web_cidr = ["0.0.0.0/0"]

# OpenClaw Configuration
openclaw_port    = 8080
openclaw_version = "latest"

# OpenRouter Configuration - Get API key from https://openrouter.ai/
openrouter_api_key = "sk-or-v1-xxxxxxxxxxxxx"
openrouter_model   = "anthropic/claude-4.5-sonnet"

# Telegram Integration (optional) - Get bot token from @BotFather
telegram_bot_token = ""

# Cost Optimization
use_spot_instance = true
spot_max_price    = "0.025"  # Minimum 0.0174 for t4g.medium
use_elastic_ip    = false
